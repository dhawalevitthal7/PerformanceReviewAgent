# ============================================================
# Root .gitignore — PerformBharat mono-repo
# ============================================================

# ----------------------------------------------------------
# Environment variables — NEVER commit real secrets
# ----------------------------------------------------------
.env
.env.local
.env.*.local
# Allow example templates
!.env.example

# ----------------------------------------------------------
# Python / Backend
# ----------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
backend/venv/
backend/env/
backend/ENV/
backend/.venv
*.db
*.sqlite
*.sqlite3
*.log

# ----------------------------------------------------------
# Node / Frontend
# ----------------------------------------------------------
perform-for-you/node_modules/
perform-for-you/dist/
perform-for-you/dist-ssr/

# ----------------------------------------------------------
# IDE & OS
# ----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----------------------------------------------------------
# Sensitive / build artefacts
# ----------------------------------------------------------
*.pem
*.key
*.cert
